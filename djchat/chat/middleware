from urllib.parse import parse_qs
from django.contrib.auth.models import AnonymousUser
from rest_framework_simplejwt.tokens import AccessToken, TokenError
from rest_framework_simplejwt.exceptions import InvalidToken
from channels.db import database_sync_to_async
from channels.middleware import BaseMiddleware
from django.contrib.auth import get_user_model
from django.conf import settings
from django.db import close_old_connections

User = get_user_model()

@database_sync_to_async
def get_user_from_token(validated_token):
    """Return the user from a validated token."""
    close_old_connections()
    try:
        user_id = validated_token.get("user_id")
        if user_id is None:
            return AnonymousUser()
        user = User.objects.get(id=user_id)
        return user if user.is_active else AnonymousUser()
    except User.DoesNotExist:
        return AnonymousUser()

class JwtCookieAuthMiddleware(BaseMiddleware):
    """
    Middleware that authenticates WebSocket connections using a JWT access token
    stored in an HttpOnly cookie named 'access_token'.
    """
    async def __call__(self, scope, receive, send):
        # Extract cookies from the headers
        headers = dict(scope.get('headers', []))
        cookie_header = headers.get(b'cookie', b'').decode('utf-8')

        access_token_value = None
        if cookie_header:
            # Simple cookie parser (handles 'key=value; key2=value2')
            cookies = {}
            for cookie in cookie_header.split('; '):
                if '=' in cookie:
                    key, value = cookie.split('=', 1)
                    cookies[key] = value
            # Use the same cookie name as in SIMPLE_JWT
            access_token_value = cookies.get(settings.SIMPLE_JWT.get('ACCESS_TOKEN_NAME', 'access_token'))

        if access_token_value is None:
            scope['user'] = AnonymousUser()
            return await super().__call__(scope, receive, send)

        try:
            # Validate the token (checks signature and expiration)
            validated_token = AccessToken(access_token_value)
            user = await get_user_from_token(validated_token)
            scope['user'] = user
        except (InvalidToken, TokenError) as e:
            print(f"WebSocket JWT auth failed: {e}")
            scope['user'] = AnonymousUser()

        return await super().__call__(scope, receive, send)


def JwtCookieAuthMiddlewareStack(inner):
    return JwtCookieAuthMiddleware(inner)